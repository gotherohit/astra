{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2022"],
		"outDir": "dist",
		"rootDir": "src",
		"strict":true,
		"esModuleInterop": true,
		"jsx": "react-jsx",
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitReturns": true

	},

	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "**/*.test.ts"]
}
